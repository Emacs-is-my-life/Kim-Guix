# Enable Python UV: Default Profile
source $USER_PYTHON_ENV_DIR/Default/bin/activate

# Marimo
marimo() {
	if [[ "$1" == "edit" ]]; then
        shift
        command marimo edit --host localhost --port 8000 --no-token --watch --allow-origins "http://localhost:8000" "$@"
	else
		command marimo "$@"
	fi
}

marimo-ai() {
	if [[ "$1" == "edit" ]]; then
		# 1. Decrypt key from authinfo.gpg
		GPG_TTY=$(tty) api_key=$(gpg --quiet --for-your-eyes-only --decrypt $HOME/Documents/Secrets/authinfo.gpg | awk '/api.openai.com/ { for(i=1;i<=NF;i++) if($i=="password") print $(i+1) }')

    	# 2. Check if decryption worked
    	if [ -z "$api_key" ]; then
           echo "Error: Could not extract OpenAI API key from authinfo.gpg"
		   return 1
    	fi

        shift
        OPENAI_API_KEY="$api_key" command marimo edit --host localhost --port 8000 --no-token --watch --allow-origins "http://localhost:8000" "$@"
	else
		command marimo "$@"
	fi
}

guix-container() {
    local default_manifest="$HOME/Documents/Container/Default.scm"
    local manifest_name=""
    local manifest_file=""
    local share_dir=""
    local -a extra_packages=()
    local -a share_args=()

    _guix_container_usage() {
        cat <<'EOF'
Usage: guix-container [MANIFEST] [--share DIR] [--add PKG...] [-h|--help]

Spin up a Guix FHS container shell with network access, using a manifest
from ~/Documents/Container/.

Arguments:
  MANIFEST          Name of the manifest (without .scm) in
                    ~/Documents/Container/. Defaults to "Default".

Options:
  --share DIR       Bind-mount host DIR (read/write) at ~/Mount inside
                    the container.
  --add PKG...      Extra packages to install on top of the manifest.
                    Consumes all following args until the next --flag.
  -h, --help        Show this help and exit.

Examples:
  guix-container
  guix-container Python
  guix-container --share ./dir
  guix-container --add graphviz jq
  guix-container Python --share ./dir --add graphviz jq
EOF
    }

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                _guix_container_usage
                return 0
                ;;
            --share)
                shift
                if [[ -z "$1" ]]; then
                    echo "guix-container: --share requires a directory" >&2
                    return 1
                fi
                share_dir="$1"
                shift
                ;;
            --add)
                shift
                while [[ $# -gt 0 && "$1" != --* ]]; do
                    extra_packages+=("$1")
                    shift
                done
                ;;
            -*)
                echo "guix-container: unknown option: $1" >&2
                echo "Try 'guix-container --help' for usage." >&2
                return 1
                ;;
            *)
                if [[ -z "$manifest_name" ]]; then
                    manifest_name="$1"
                    shift
                else
                    echo "guix-container: unexpected argument: $1" >&2
                    return 1
                fi
                ;;
        esac
    done

    if [[ -z "$manifest_name" ]]; then
        manifest_file="$default_manifest"
    else
        manifest_file="$HOME/Documents/Container/${manifest_name}.scm"
    fi

    if [[ ! -f "$manifest_file" ]]; then
        echo "guix-container: manifest not found: $manifest_file" >&2
        return 1
    fi

    if [[ -n "$share_dir" ]]; then
        if [[ ! -d "$share_dir" ]]; then
            echo "guix-container: share dir not found: $share_dir" >&2
            return 1
        fi
        local abs_share
        abs_share="$(realpath "$share_dir")"
        # Mount host directory at $HOME/Mount inside the container.
        share_args=(--share="${abs_share}=${HOME}/Mount")
    fi

    guix shell --container --emulate-fhs --network \
        --no-cwd \
        --preserve='^TERM$' \
        --preserve='^COLORTERM$' \
        --preserve='^LANG$' \
        --preserve='^LC_' \
        "${share_args[@]}" \
        -m "$manifest_file" \
        "${extra_packages[@]}" \
        -- bash
}
