# Enable Python UV: Default Profile
source $USER_PYTHON_ENV_DIR/Default/bin/activate

# Marimo
marimo() {
	if [[ "$1" == "edit" ]]; then
        shift
        command marimo edit --host localhost --port 8000 --no-token --allow-origins "http://localhost:8000" "$@"
	else
		command marimo "$@"
	fi
}

marimo-ai() {
	if [[ "$1" == "edit" ]]; then
		# 1. Decrypt key from authinfo.gpg
		GPG_TTY=$(tty) api_key=$(gpg --quiet --for-your-eyes-only --decrypt ~/Documents/Secrets/authinfo.gpg | awk '/api.openai.com/ { for(i=1;i<=NF;i++) if($i=="password") print $(i+1) }')

    	# 2. Check if decryption worked
    	if [ -z "$api_key" ]; then
           echo "Error: Could not extract OpenAI API key from authinfo.gpg"
		   return 1
    	fi

        shift
        OPENAI_API_KEY="$api_key" command marimo edit --host localhost --port 8000 --no-token --allow-origins "http://localhost:8000" "$@"
	else
		command marimo "$@"
	fi
}

guix-container() {
    local manifest="$1"
    local share_dir="${2:-$PWD}"

    if [[ -z "$manifest" ]]; then
	    guix shell --container --emulate-fhs --network \
        --preserve='^TERM$' \
		--preserve='^COLORTERM$' \
		--preserve='^LANG$' \
		--preserve='^LC_' \
        --share="$share_dir" \
        -m "~/Documents/Guix/user/guix-containers/Claude-Code.scm" \
        -- bash
    fi
	
    if [[ ! -f "$manifest" ]]; then
        echo "guix-container: manifest not found: $manifest" >&2
        return 1
    fi
    if [[ ! -d "$share_dir" ]]; then
        echo "guix-container: share dir not found: $share_dir" >&2
        return 1
    fi

    guix shell --container --emulate-fhs --network \
	    --preserve='^TERM$' \
		--preserve='^COLORTERM$' \
		--preserve='^LANG$' \
		--preserve='^LC_' \
        --share="$share_dir" \
        -m "$manifest" \
        -- bash
}
